anthropicApiKey: ""

kafka:
  brokers:
    - "127.0.0.1:9092"
  clientId: "commit-review-bot"
  groupId: "commit-review-bot"
  topic: "code-events"
  ssl: false
  sasl:
    enabled: false
    mechanism: "plain"
    username: ""
    password: ""

repo:
  baseDir: "/absolute/path/to/local-repos"
  defaultRewrite:
    from: ""
    to: ""
  repos:
    "Jackie/ronds-knowbase":
      localPath: "/absolute/path/to/local-repos/Jackie/ronds-knowbase"
      cloneUrl: "ssh://git@172.16.0.9:30000/Jackie/ronds-knowbase.git"
      rewrite:
        from: "http://172.16.0.9:30000"
        to: "ssh://git@172.16.0.9:30000"

claude:
  maxTurns: 8
  minScore: 70
  allowedTools:
    - "Skill"
    - "Read"
    - "Glob"
    - "Grep"
    - "Bash"

feishu:
  webhookUrl: ""
  atIdType: "user_id"
  userMapFile: "./feishu-users.json"
